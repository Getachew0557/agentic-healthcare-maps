APP_ENV=dev
APP_NAME=agentic-healthcare-maps
APP_HOST=0.0.0.0
APP_PORT=8000

# Database — this key only (not `DATABASE_URL`) so system env cannot force Postgres by mistake
CHATMAP_DATABASE_URL=sqlite+pysqlite:///./app.db

# PostgreSQL (optional)
# CHATMAP_DATABASE_URL=postgresql+psycopg2://postgres:root@localhost:5432/ahm

# Auth
JWT_SECRET=change_me
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Integrations
GEMINI_API_KEY=
TAVILY_API_KEY=
ORS_API_KEY=   # OpenRouteService — free signup at https://openrouteservice.org/dev/#/signup

# Notes:
# - Do NOT commit real secrets.
# - Tavily code `TVLY-HF9ETJRW` is the hackathon credit code you redeem on `https://www.tavily.com`
#   to generate your own `TAVILY_API_KEY`. Paste the generated API key here.

# Redis (optional in starter)
REDIS_URL=redis://localhost:6379/0

# Chroma (optional in starter)
CHROMA_PERSIST_DIR=./chroma_data

# Local test logins (after hospitals exist in DB), run: python scripts/seed_dev_accounts.py
#   chatmap-admin@example.com  /  ChatMap2026!Dev  → /admin
#   chatmap-staff@example.com  /  ChatMap2026!Dev  → /dashboard (first hospital in DB)
# (Avoid domains like @something.test — EmailStr rejects special-use TLDs.)
