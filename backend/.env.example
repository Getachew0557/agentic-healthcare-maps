APP_ENV=dev
APP_NAME=agentic-healthcare-maps
APP_HOST=0.0.0.0
APP_PORT=8000

# Database — PostgreSQL (primary)
DATABASE_URL=postgresql+psycopg2://postgres:root@localhost:5432/ahm

# Docker Compose Postgres (use this when running via docker-compose up)
# DATABASE_URL=postgresql+psycopg2://ahm:ahm@localhost:5432/ahm

# SQLite fallback for quick local dev without Postgres
# DATABASE_URL=sqlite+pysqlite:///./app.db

# Auth
JWT_SECRET=change_me
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Integrations
GEMINI_API_KEY=
TAVILY_API_KEY=
ORS_API_KEY=   # OpenRouteService — free signup at https://openrouteservice.org/dev/#/signup

# Notes:
# - Do NOT commit real secrets.
# - Tavily code `TVLY-HF9ETJRW` is the hackathon credit code you redeem on `https://www.tavily.com`
#   to generate your own `TAVILY_API_KEY`. Paste the generated API key here.

# Redis (optional in starter)
REDIS_URL=redis://localhost:6379/0

# Chroma (optional in starter)
CHROMA_PERSIST_DIR=./chroma_data
