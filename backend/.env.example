APP_ENV=dev
APP_NAME=agentic-healthcare-maps
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (use Postgres in prod; SQLite is fine for local starter)
DATABASE_URL=sqlite+pysqlite:///./app.db

# Example Postgres (DO NOT commit real passwords)
# DATABASE_URL=postgresql+psycopg://ahm:ahm@localhost:5432/ahm

# Example MySQL (DO NOT commit real passwords)
# DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/agentic_healthcare_maps

# Auth
JWT_SECRET=change_me
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Integrations
GEMINI_API_KEY=
TAVILY_API_KEY=

# Notes:
# - Do NOT commit real secrets.
# - Tavily code `TVLY-HF9ETJRW` is the hackathon credit code you redeem on `https://www.tavily.com`
#   to generate your own `TAVILY_API_KEY`. Paste the generated API key here.

# Redis (optional in starter)
REDIS_URL=redis://localhost:6379/0

# Chroma (optional in starter)
CHROMA_PERSIST_DIR=./chroma_data
