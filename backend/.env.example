# ─────────────────────────────────────────────────────────────────────────────
# Agentic Healthcare Maps — Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_ENV=dev
APP_NAME=agentic-healthcare-maps
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Database ─────────────────────────────────────────────────────────────────
# Primary database (PostgreSQL recommended)
DATABASE_URL=postgresql+psycopg2://postgres:root@localhost:5432/ahm

# Docker Compose Postgres (use when running via docker compose up)
# DATABASE_URL=postgresql+psycopg2://ahm:ahm@localhost:5432/ahm

# SQLite fallback for quick local dev without Postgres
# DATABASE_URL=sqlite+pysqlite:///./app.db

# Test database — separate DB so tests never touch production data
TEST_DATABASE_URL=postgresql+psycopg2://postgres:root@localhost:5432/ahm_test

# ── Authentication ────────────────────────────────────────────────────────────
# IMPORTANT: Change JWT_SECRET to a long random string in production
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# CORS_ALLOW_ORIGINS=http://localhost:5173,https://yourdomain.com

# ── AI / LLM APIs (all free) ─────────────────────────────────────────────────
# Google Gemini — free tier, 60 req/min
# Get key at: https://aistudio.google.com
GEMINI_API_KEY=

# Tavily Search — real-time medical citations
# Redeem hackathon code TVLY-HF9ETJRW at https://www.tavily.com to get your key
TAVILY_API_KEY=

# OpenRouteService — driving ETA calculations (optional, graceful fallback)
# Free signup at: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# ── Cache / Real-time ────────────────────────────────────────────────────────
# Redis for WebSocket pub/sub (optional — app works without it)
REDIS_URL=redis://localhost:6379/0

# ── Vector Search ────────────────────────────────────────────────────────────
# Chroma persistent storage directory
CHROMA_PERSIST_DIR=./chroma_data

# ── Live Test ────────────────────────────────────────────────────────────────
# Base URL for test_chat_live.py (server must be running)
API_BASE_URL=http://localhost:8000/api/v1
