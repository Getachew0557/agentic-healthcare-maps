APP_ENV=dev
APP_NAME=agentic-healthcare-maps
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (use Postgres in prod; SQLite is fine for local starter)
DATABASE_URL=sqlite+pysqlite:///./app.db

# Auth
JWT_SECRET=change_me
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Integrations
GEMINI_API_KEY=
TAVILY_API_KEY=

# Redis (optional in starter)
REDIS_URL=redis://localhost:6379/0

# Chroma (optional in starter)
CHROMA_PERSIST_DIR=./chroma_data
