# ─────────────────────────────────────────────────────────────────────────────
# Agentic Healthcare Maps — Frontend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL
# Local dev:
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Docker Compose (frontend container talks to backend container):
# VITE_API_BASE_URL=http://backend:8000/api/v1

# Production (replace with your deployed backend URL):
# VITE_API_BASE_URL=https://api.yourdomain.com/api/v1

# WebSocket URL for real-time availability updates
# Local dev:
VITE_WS_URL=ws://localhost:8000/api/v1/ws/availability

# Production:
# VITE_WS_URL=wss://api.yourdomain.com/api/v1/ws/availability
