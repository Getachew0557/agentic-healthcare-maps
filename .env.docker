# Docker Compose environment variables
# Copy this to .env and fill in your values:
#   cp .env.docker .env

# PostgreSQL
POSTGRES_USER=ahm
POSTGRES_PASSWORD=ahm
POSTGRES_DB=ahm

# Backend
JWT_SECRET=change_me_to_a_long_random_string
APP_ENV=production

# API Keys (all free)
GEMINI_API_KEY=
TAVILY_API_KEY=
ORS_API_KEY=

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
